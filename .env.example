# Copy to .env and fill in. Never commit the real .env.

# ── AI ──────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ── Supabase (Project Settings → API) ────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Auth is Google OAuth via Supabase — enable the Google provider in the Supabase
# dashboard (Authentication → Providers → Google) with a Google Cloud Client ID + Secret.
# Multi-user: anyone can sign in with Google; data is isolated per user by RLS.

# ── Model strings (verified available; override if they change) ───────────────
ANTHROPIC_MODEL=claude-sonnet-4-6
GEMINI_FOOD_MODEL=gemini-3.5-flash
GEMINI_EXERCISE_MODEL=gemini-3.5-flash
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
